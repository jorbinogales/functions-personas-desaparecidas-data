# --- Almacenamiento ---
# Si defines las variables del Railway Bucket (abajo), se usa el bucket S3.
# Si NO, se usa el filesystem en DATA_DIR (Volume en Railway o ./data en local).
DATA_DIR=./data

# --- Railway Bucket (S3) ---  Railway las auto-inyecta al adjuntar el bucket.
# BUCKET_NAME=
# BUCKET_ENDPOINT=
# BUCKET_ACCESS_KEY_ID=
# BUCKET_SECRET_ACCESS_KEY=
# BUCKET_REGION=us-east-1

# Milisegundos de espera entre peticiones (cortesía con el servidor).
REQUEST_DELAY_MS=600

# Tras encontrar N páginas seguidas SIN nada nuevo, deja de paginar ese estado.
STOP_AFTER_KNOWN_PAGES=2

# Tope de seguridad de páginas por estado.
MAX_PAGES=2000

# "1" fuerza recorrer TODAS las páginas (úsalo para el backfill inicial).
FULL_SCAN=0

# "0" desactiva traer la página de detalle (género, última vez visto, etc.) de los nuevos.
ENRICH_NEW=1

# Si >0, además enriquece esa cantidad de reportes viejos aún sin detalle (backfill gradual).
ENRICH_BATCH=0

# User-Agent identificable.
USER_AGENT=VenezuelaReportaArchiver/1.0 (proyecto humanitario de respaldo de desaparecidos)
